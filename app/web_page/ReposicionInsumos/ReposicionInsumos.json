      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.reposicionInsumos && $data.reposicionInsumos_insumo ){",
        "\t//attach lazy references variables to parent variables",
        "\t$data.reposicionInsumos.insumo = $data.reposicionInsumos_insumo;",
        "\treturn {",
        "\t\t//map reposicionInsumos variable to expected task contract input",
        "\t\treposicionInsumosInput: {",
        "\t\t\tidSede: $data.reposicionInsumos.idSede !== undefined ? $data.reposicionInsumos.idSede : null,",
        "\t\t\tidReposicion: $data.reposicionInsumos.idReposicion !== undefined ? $data.reposicionInsumos.idReposicion : null,",
        "\t\t\tfechaSolicitud: $data.reposicionInsumos.fechaSolicitud !== undefined ? $data.reposicionInsumos.fechaSolicitud : null,",
        "\t\t\testaAprobado: $data.reposicionInsumos.estaAprobado !== undefined ? $data.reposicionInsumos.estaAprobado : null,",
        "\t\t\tesUrgente: $data.reposicionInsumos.esUrgente !== undefined ? $data.reposicionInsumos.esUrgente : null,",
        "\t\t\tinsumo: $data.reposicionInsumos.insumo.map( it => ({",
        "\t\t\t\tpersistenceId_string: it.persistenceId_string !== undefined ? it.persistenceId_string : null,",
        "\t\t\t\tidInsumo: it.idInsumo !== undefined ? it.idInsumo : null,",
        "\t\t\t\tnombreInsumo: it.nombreInsumo !== undefined ? it.nombreInsumo : null,",
        "\t\t\t\tunidadMedida: it.unidadMedida !== undefined ? it.unidadMedida : null,",
        "\t\t\t\tcantidad: it.cantidad !== undefined ? it.cantidad : null",
        "\t\t\t}))",
        "\t\t}",
        "\t}",
        "}"
