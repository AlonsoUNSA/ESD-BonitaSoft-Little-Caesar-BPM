  "variables" : {
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.controlCalidad ){",
        "\treturn {",
        "\t\t//map controlCalidad variable to expected task contract input",
        "\t\tcontrolCalidadInput: {",
        "\t\t\tidControl: $data.controlCalidad.idControl !== undefined ? $data.controlCalidad.idControl : null,",
        "\t\t\tfechaRevision: $data.controlCalidad.fechaRevision !== undefined ? $data.controlCalidad.fechaRevision : null,",
        "\t\t\tcumpleCalidad: $data.controlCalidad.cumpleCalidad !== undefined ? $data.controlCalidad.cumpleCalidad : null,",
        "\t\t\tobservaciones: $data.controlCalidad.observaciones !== undefined ? $data.controlCalidad.observaciones : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
