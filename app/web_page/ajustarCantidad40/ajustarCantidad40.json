    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.unaSolicitudDeInsumo ){",
        "\treturn {",
        "\t\t//map unaSolicitudDeInsumo variable to expected task contract input",
        "\t\tunaSolicitudDeInsumoInput: {",
        "\t\t\tesUrgente: $data.unaSolicitudDeInsumo.esUrgente !== undefined ? $data.unaSolicitudDeInsumo.esUrgente : null,",
        "\t\t\tnombreInsumo: $data.unaSolicitudDeInsumo.nombreInsumo !== undefined ? $data.unaSolicitudDeInsumo.nombreInsumo : null,",
        "\t\t\tunidadInsumo: $data.unaSolicitudDeInsumo.unidadInsumo !== undefined ? $data.unaSolicitudDeInsumo.unidadInsumo : null,",
        "\t\t\tcantidadInsumo: $data.unaSolicitudDeInsumo.cantidadInsumo !== undefined ? $data.unaSolicitudDeInsumo.cantidadInsumo : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
