        "\t//attach lazy references variables to parent variables",
        "\t$data.solicitudDeInsumo.insumo = $data.solicitudDeInsumo_insumo;",
        "\treturn {",
        "\t\t//map solicitudDeInsumo variable to expected task contract input",
        "\t\tsolicitudDeInsumoInput: {",
        "\t\t\tidSede: $data.solicitudDeInsumo.idSede !== undefined ? $data.solicitudDeInsumo.idSede : null,",
        "\t\t\tfechaSolicitud: $data.solicitudDeInsumo.fechaSolicitud !== undefined ? $data.solicitudDeInsumo.fechaSolicitud : null,",
        "\t\t\tesUrgente: $data.solicitudDeInsumo.esUrgente !== undefined ? $data.solicitudDeInsumo.esUrgente : null,",
        "\t\t\tinsumo: $data.solicitudDeInsumo.insumo.map( it => ({",
        "\t\t\t\tpersistenceId_string: it.persistenceId_string !== undefined ? it.persistenceId_string : null,",
        "\t\t\t\tnombreInsumo: it.nombreInsumo !== undefined ? it.nombreInsumo : null,",
        "\t\t\t\tunidadMedida: it.unidadMedida !== undefined ? it.unidadMedida : null,",
        "\t\t\t\tcantidad: it.cantidad !== undefined ? it.cantidad : null",
        "\t\t\t}))",
        "\t\t}",
        "\t}",
        "}"
