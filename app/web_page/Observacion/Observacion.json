  "variables" : {
    "pedido_idControl" : {
      "type" : "url",
      "value" : [
        "{{pedido|lazyRef:'idControl'}}"
      ],
      "exposed" : false
    },
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "pedido_insumos" : {
      "type" : "url",
      "value" : [
        "{{pedido|lazyRef:'insumos'}}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.pedido && $data.pedido_idControl && $data.pedido_insumos && $data.pedido_reposiciones ){",
        "\t//attach lazy references variables to parent variables",
        "\t$data.pedido.idControl = $data.pedido_idControl;",
        "\t$data.pedido.insumos = $data.pedido_insumos;",
        "\t$data.pedido.reposiciones = $data.pedido_reposiciones;",
        "\treturn {",
        "\t\t//map pedido variable to expected task contract input",
        "\t\tpedidoInput: {",
        "\t\t\tobservaciones: $data.pedido.observaciones !== undefined ? $data.pedido.observaciones : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "pedido" : {
      "type" : "url",
      "value" : [
        "../{{context.pedido_ref.link}}"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    },
    "pedido_reposiciones" : {
      "type" : "url",
      "value" : [
        "{{pedido|lazyRef:'reposiciones'}}"
      ],
      "exposed" : false
    }
